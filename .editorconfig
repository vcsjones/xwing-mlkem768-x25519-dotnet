root = true

[*.cs]
charset = utf-8
insert_final_newline = true
indent_style = space
indent_size = 4
trim_trailing_whitespace = true

# Formatting
csharp_new_line_before_open_brace = none # k&r styling

# IDE0305: Simplify collection initialization
dotnet_style_prefer_collection_expression = never

[*.csproj,*.slnx,*.props,*.yml,*.json]
charset = utf-8
insert_final_newline = true
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
